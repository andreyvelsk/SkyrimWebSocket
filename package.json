{
  "name": "skyrim-websocket",
  "version": "1.4.0",
  "description": "An SKSE plugin for Skyrim that provides a WebSocket server interface for remote game state monitoring and control",
  "type": "module",
  "scripts": {
    "release": "standard-version && node scripts/update-version.js $(node -p \"require('./package.json').version\")",
    "release:dry-run": "standard-version --dry-run",
    "prepare": "husky install || true"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/yourusername/SkyrimWebSocket.git"
  },
  "keywords": [
    "skyrim",
    "skse",
    "websocket",
    "modding"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@commitlint/cli": "^19.3.0",
    "@commitlint/config-conventional": "^19.2.2",
    "husky": "^9.1.6",
    "standard-version": "^9.5.0"
  }
}
